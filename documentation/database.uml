@startuml

hide methods
skinparam classAttributeIconSize 0

' =========================
' Entities
' =========================

class User {
  first_name : String(50)
}

class Game {
  day : Date
  time : Integer
  game_number : String(20)
}

class Championship {
  name : String
  season : String(9)?
  short_code : String(10)?
  category : TeamCategory?
  gender : Gender?
}

class Group {
  name : String(50)
}

class Player {
  last_name : String(50)
  first_name : String(50)
}

class Coach {
  last_name : String(50)
  first_name : String(50)
}

class Officer {
  name : String(100)
}

class GameOfficer {
  role : GameOfficerRole
  rank : Integer
}

enum TeamCategory {
  U5
  U6
  U7
  U8
  U9
  U10
  U11
  U12
  U13
  U14
  U15
  U16
  U17
  U18
  U19
  U20
  U21
  Senior
}

enum Gender {
  Male
  Female
}

enum GameOfficerRole {
  referee
  club_delegate
  time_tracker
  scorer
}

class PlayerStatRow {
  number : Integer
  starter : Boolean
  time_played : Integer
  points : Integer
  shots_made : Integer
  three_pts_made : Integer
  two_pts_in_made : Integer
  two_pts_out_made : Integer
  ft_made : Integer
  fouls : Integer
}

class CoachStatRow {
  fouls : Integer
}

enum TeamStatType {
  team
  bench
  starters
  first_half
  second_half
  overtime
}

class TeamStatRow {
  time_played : Integer?
  points : Integer?
  shots_made : Integer?
  three_pts_made : Integer?
  two_pts_in_made : Integer?
  two_pts_out_made : Integer?
  ft_made : Integer?
  fouls : Integer?
  type : TeamStatType
}

class File {
  name : String(100)
  location : String(256)
  hash : String(64)
  extracted_data : JSON?
}

enum GameImportStatus {
  pending
  ready
  failed
}

class GameImport {
  status : GameImportStatus
  error_message : Text?
  filename : String(256)
  league_code : String(20)
  championship_code : String(50)
  group_name : String(50)
  game_number : String(20)
  team_a_name : String(100)
  team_a_suffix : String(10)?
  team_b_name : String(100)
  team_b_suffix : String(10)?
  created_at : Timestamp
  updated_at : Timestamp
  extracted_at : Timestamp?
}

class Team {
  name : String(100)
  suffix : String(10)?
  category : TeamCategory?
  gender : Gender?
}

class Club {
  name : String(100)
  code : String(20)?
}

class Venue {
  name : String(100)
  address : String(256)?
}

' =========================
' Relationships
' =========================

Game --> Venue : venue
Game --> Group : group
Game --> Team : team_a
Game --> Team : team_b

GameOfficer --> Game : game
GameOfficer --> Officer : officer
GameOfficer --> GameOfficerRole : role

Group --> Championship : championship

Player --> Club : club
Coach --> Club : club

PlayerStatRow --> Game : game
PlayerStatRow --> Player : player

CoachStatRow --> Game : game
CoachStatRow --> Coach : coach

TeamStatRow --> Game : game
TeamStatRow --> Team : team

Team --> Club : club

Venue --> Club : club

File --> Game : game

' =========================
' Cardinalities
' =========================

Championship "1" <-- "*" Group
Group "1" <-- "*" Game

Venue "1" <-- "*" Game

Team "1" <-- "*" Game : team_a
Team "1" <-- "*" Game : team_b

Game "1" <-- "*" GameOfficer
Officer "1" <-- "*" GameOfficer

Club "0..1" <-- "*" Venue
Club "1" <-- "*" Team
Club "1" <-- "*" Player
Club "1" <-- "*" Coach

Player "1" <-- "*" PlayerStatRow
Coach "1" <-- "*" CoachStatRow

Game "1" <-- "*" TeamStatRow
Team "1" <-- "*" TeamStatRow

Game "0..1" <-- "*" File

GameImport --> File : file
GameImport --> Game : game
GameImport --> GameImportStatus : status

File "0..1" <-- "*" GameImport
Game "0..1" <-- "*" GameImport

@enduml
